/*
  Cloudflare Pages — Security & Performance Headers
  https://developers.cloudflare.com/pages/platform/headers/

  Estos headers se aplican a todas las respuestas del sitio.
  Objetivo: A+ en securityheaders.com y correcta caché de assets.
*/

# ── Todas las páginas ──────────────────────────────────────────────────
/*
  # Seguridad
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

  # CSP ajustada a los recursos reales de la página
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https: data:; connect-src 'self'; frame-ancestors 'none'

  # Cache control para HTML — nunca cachear el documento
  Cache-Control: no-cache, no-store, must-revalidate

# ── Assets estáticos (CSS / imágenes / fuentes locales) — larga caché ──
/style.css
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable
