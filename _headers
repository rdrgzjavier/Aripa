/*
  Cloudflare Pages — Security & Performance Headers
  https://developers.cloudflare.com/pages/platform/headers/

  Estos headers se aplican a todas las respuestas del sitio.
  Objetivo: A+ en securityheaders.com y correcta caché de assets.
*/

# ── Todas las páginas ──────────────────────────────────────────────────
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://app.cal.com https://cal.com https://*.clarity.ms https://api.kiprotect.com https://assets.mailerlite.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://assets.mailerlite.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' https: data:; connect-src 'self' https://www.googletagmanager.com https://app.cal.com https://cal.com https://*.clarity.ms https://api.kiprotect.com https://formspree.io https://assets.mailerlite.com https://ml-eu.mailerlite.com; frame-src https://app.cal.com https://cal.com; frame-ancestors 'none'
  Cache-Control: no-cache, no-store, must-revalidate

# ── Assets estáticos (CSS / imágenes / fuentes locales) — larga caché ──
/style.css
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable
